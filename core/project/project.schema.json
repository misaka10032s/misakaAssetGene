{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MisakaAssetGene Project Schema",
  "type": "object",
  "required": ["id", "name", "type", "synopsis"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable project route id and folder slug generated by the app."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable project title shown in the UI."
    },
    "type": {
      "type": "string",
      "minLength": 1,
      "examples": ["RPG", "Visual Novel", "Narrative Puzzle Adventure"]
    },
    "synopsis": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
